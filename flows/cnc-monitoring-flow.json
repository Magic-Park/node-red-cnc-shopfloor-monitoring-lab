        "type": "function",
        "z": "e902722bc10202f6",
        "name": "Build Alarm History Table",
        "func": "let alarms = flow.get(\"alarmHistory\") || [];\n\nlet alarmEntry = {\n    time: msg.event_time,\n    machine: msg.machine_id,\n    status: msg.status,\n    severity: msg.severity,\n    message: msg.message,\n    source: msg.source\n};\n\nalarms.unshift(alarmEntry);\n\nalarms = alarms.slice(0, 10);\n\nflow.set(\"alarmHistory\", alarms);\n\nmsg.payload = alarms;\n\nreturn msg;",
