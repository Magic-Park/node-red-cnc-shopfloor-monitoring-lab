        "name": "Prepare Status JSONL Log",
        "func": "let statusLogEntry = {\n    event_time: msg.event_time,\n    machine_id: msg.machine_id,\n    topic: msg.topic,\n    status: msg.payload,\n    source: msg.source,\n    event_type: \"MACHINE_STATUS\"\n};\n\nmsg.payload = JSON.stringify(statusLogEntry) + \"\\n\";\nmsg.filename = \"D:/node-red/Logs/JSONLine/status_log.jsonl\";\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 760,
