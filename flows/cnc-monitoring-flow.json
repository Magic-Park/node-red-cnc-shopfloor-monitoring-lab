        "type": "function",
        "z": "e902722bc10202f6",
        "name": "Build ALARM event",
        "func": "if (msg.payload !== \"ALARM\") {\n    node.warn(\"Build Alarm Event received non-ALARM status: \" + msg.payload);\n    return null;\n}\n\nif (msg.previous_status === \"ALARM\") {\n    node.warn(\"Duplicate ALARM ignored. Machine is already in ALARM state.\");\n    return null;\n}\n\nmsg.status = msg.payload;\nmsg.event_type = \"MACHINE_ALARM\";\nmsg.severity = \"HIGH\";\nmsg.message = msg.machine_id + \" reported ALARM status\";\n\nreturn msg;",
