    {
        "id": "8877287289276031",
        "type": "function",
        "z": "e902722bc10202f6",
        "name": "Build Machine Message",
        "func": "let status = String(msg.payload).trim().toUpperCase();\n\nlet allowedStatuses = [\"RUNNING\", \"STOPPED\", \"ALARM\"];\n\nif (!allowedStatuses.includes(status)) {\n    node.warn(\"Invalid machine status: \" + msg.payload);\n    return null;\n}\n\nlet previousStatus = flow.get(\"currentMachineStatus\") || null;\n\nmsg.payload = status;\nmsg.topic = \"shopfloor/cnc01/status\";\nmsg.machine_id = \"CNC-01\";\nmsg.event_time = new Date().toISOString();\nmsg.previous_status = previousStatus;\nmsg.is_status_change = previousStatus !== status;\n\nif (msg._client) {\n    msg.source = \"dashboard\";\n} else {\n    msg.source = \"inject\";\n}\n\nflow.set(\"currentMachineStatus\", status);\n\ndelete msg._client;\ndelete msg._event;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 450,
        "y": 480,
        "wires": [
            [
                "ca67b5102e94a6cd",
                "4f05f5ad33c004ba"
            ]
        ]
    },
    {
        "id": "4f05f5ad33c004ba",
        "type": "function",
